rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'admin@socio.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.uid is string && 
             data.uid == request.auth.uid &&
             data.username is string && 
             data.username.size() > 0 && 
             data.role in ['user', 'admin'] &&
             (data.role == 'user' || request.auth.token.email == 'admin@socio.com' || isAdmin());
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && 
                       isValidId(userId) && 
                       userId == request.auth.uid && 
                       isValidUser(incoming());
      
      allow update: if isSignedIn() && 
                       isValidId(userId) && 
                       userId == request.auth.uid && 
                       isValidUser(incoming()) && (
                         isAdmin() ||
                         (incoming().role == existing().role && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['username', 'avatar', 'isOnline', 'currentRoomId', 'lastActive', 'email', 'coins', 'exp', 'level', 'ownedAvatars', 'lastRewardClaimed', 'loginStreak', 'completedChallenges', 'badges']))
                       );
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
                         incoming().senderId == request.auth.uid &&
                         incoming().timestamp == request.time;
        allow update: if isSignedIn() && (
          isAdmin() ||
          (isOwner(existing().senderId) && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'type', 'mediaUrl'])) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['favorites', 'isPinned']))
        );
        allow delete: if isSignedIn() && (isOwner(existing().senderId) || isAdmin());
      }
    }

    match /activities/{activityId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                       isValidId(activityId) &&
                       incoming().userId == request.auth.uid &&
                       incoming().timestamp == request.time;
    }

    match /discussionPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       isValidId(postId) &&
                       incoming().authorId == request.auth.uid &&
                       incoming().timestamp == request.time &&
                       incoming().votes == 0 &&
                       incoming().replyCount == 0;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'category'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['votes', 'votedBy']))
      );
      allow delete: if isSignedIn() && (isOwner(existing().authorId) || isAdmin());
      
      match /replies/{replyId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         isValidId(replyId) &&
                         incoming().authorId == request.auth.uid &&
                         incoming().timestamp == request.time;
        allow delete: if isSignedIn() && (isOwner(existing().authorId) || isAdmin());
      }
    }

    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && 
                       isValidId(pollId) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['options', 'voters', 'totalVotes']) &&
                       !existing().voters.hasAny([request.auth.uid]);
    }

    match /sharedWorks/{workId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       isValidId(workId) &&
                       incoming().authorId == request.auth.uid &&
                       incoming().timestamp == request.time;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'files'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy']))
      );
      allow delete: if isSignedIn() && (isOwner(existing().authorId) || isAdmin());
    }
  }
}
